' ---------------------------------------------------------
' Fragment helpers
' IMPORTANT:
' Use these macros instead of raw alt/else/par/loop/...
' if you want consistent color semantics.
'
' Info   = normal / operational / expected path
' Warn   = degraded / fallback / retry / exception path
' Crit   = money / safety / idempotency / hard-risk path
' ---------------------------------------------------------

' ----- ALT / ELSE -----
!procedure SEQ_ALT_INFO($LABEL)
    alt#$FR_INFO_HEAD #$FR_INFO_BG $LABEL
!endprocedure

!procedure SEQ_ALT_WARN($LABEL)
    alt#$FR_WARN_HEAD #$FR_WARN_BG $LABEL
!endprocedure

!procedure SEQ_ALT_CRIT($LABEL)
    alt#$FR_CRIT_HEAD #$FR_CRIT_BG $LABEL
!endprocedure

!procedure SEQ_ELSE_INFO($LABEL)
    else #$FR_INFO_BG $LABEL
!endprocedure

!procedure SEQ_ELSE_WARN($LABEL)
    else #$FR_WARN_BG $LABEL
!endprocedure

!procedure SEQ_ELSE_CRIT($LABEL)
    else #$FR_CRIT_BG $LABEL
!endprocedure

!procedure SEQ_ELSE_NEUTRAL($LABEL)
    else #$FR_NEUTRAL_BG $LABEL
!endprocedure

' Default aliases
!procedure SEQ_ALT($LABEL)
    alt#$FR_INFO_HEAD #$FR_INFO_BG $LABEL
!endprocedure

!procedure SEQ_ELSE($LABEL)
    else #$FR_INFO_BG $LABEL
!endprocedure

' ----- OPT -----
!procedure SEQ_OPT_INFO($LABEL)
    opt#$FR_INFO_HEAD #$FR_INFO_BG $LABEL
!endprocedure

!procedure SEQ_OPT_WARN($LABEL)
    opt#$FR_WARN_HEAD #$FR_WARN_BG $LABEL
!endprocedure

!procedure SEQ_OPT_CRIT($LABEL)
    opt#$FR_CRIT_HEAD #$FR_CRIT_BG $LABEL
!endprocedure

!procedure SEQ_OPT($LABEL)
    opt#$FR_INFO_HEAD #$FR_INFO_BG $LABEL
!endprocedure

' ----- LOOP -----
!procedure SEQ_LOOP_INFO($LABEL)
    loop#$FR_INFO_HEAD #$FR_INFO_BG $LABEL
!endprocedure

!procedure SEQ_LOOP_WARN($LABEL)
    loop#$FR_WARN_HEAD #$FR_WARN_BG $LABEL
!endprocedure

!procedure SEQ_LOOP_CRIT($LABEL)
    loop#$FR_CRIT_HEAD #$FR_CRIT_BG $LABEL
!endprocedure

!procedure SEQ_LOOP($LABEL)
    loop#$FR_INFO_HEAD #$FR_INFO_BG $LABEL
!endprocedure

' ----- PAR -----
!procedure SEQ_PAR_INFO($LABEL)
    par#$FR_INFO_HEAD #$FR_INFO_BG $LABEL
!endprocedure

!procedure SEQ_PAR_WARN($LABEL)
    par#$FR_WARN_HEAD #$FR_WARN_BG $LABEL
!endprocedure

!procedure SEQ_PAR_CRIT($LABEL)
    par#$FR_CRIT_HEAD #$FR_CRIT_BG $LABEL
!endprocedure

!procedure SEQ_PAR($LABEL)
    par#$FR_INFO_HEAD #$FR_INFO_BG $LABEL
!endprocedure

' ----- BREAK -----
!procedure SEQ_BREAK_WARN($LABEL)
    break#$FR_WARN_HEAD #$FR_WARN_BG $LABEL
!endprocedure

!procedure SEQ_BREAK_CRIT($LABEL)
    break#$FR_CRIT_HEAD #$FR_CRIT_BG $LABEL
!endprocedure

!procedure SEQ_BREAK($LABEL)
    break#$FR_WARN_HEAD #$FR_WARN_BG $LABEL
!endprocedure

' ----- CRITICAL -----
!procedure SEQ_CRITICAL_RED($LABEL)
    critical#$FR_CRIT_HEAD #$FR_CRIT_BG $LABEL
!endprocedure

!procedure SEQ_CRITICAL($LABEL)
    critical#$FR_CRIT_HEAD #$FR_CRIT_BG $LABEL
!endprocedure

' ----- GROUP -----
!procedure SEQ_GROUP_INFO($LABEL)
    group#$FR_INFO_HEAD #$FR_INFO_BG $LABEL
!endprocedure

!procedure SEQ_GROUP_WARN($LABEL)
    group#$FR_WARN_HEAD #$FR_WARN_BG $LABEL
!endprocedure

!procedure SEQ_GROUP_CRIT($LABEL)
    group#$FR_CRIT_HEAD #$FR_CRIT_BG $LABEL
!endprocedure

!procedure SEQ_GROUP($LABEL)
    group#$FR_INFO_HEAD #$FR_INFO_BG $LABEL
!endprocedure

' ---------------------------------------------------------
' Ref / notes helpers
' ---------------------------------------------------------
!procedure SEQ_REF($WHO, $TEXT)
    ref over $WHO
        $TEXT
    end ref
!endprocedure

!procedure SEQ_NOTE_RIGHT($WHO, $TEXT)
    note right of $WHO
        $TEXT
    end note
!endprocedure

!procedure SEQ_NOTE_LEFT($WHO, $TEXT)
    note left of $WHO
        $TEXT
    end note
!endprocedure

!procedure SEQ_NOTE_OVER($WHO, $TEXT)
    note over $WHO
        $TEXT
    end note
!endprocedure

' ---------------------------------------------------------
' Arrow helpers
' ---------------------------------------------------------
!procedure SEQ_REQ($FROM, $TO, $LABEL)
    $FROM -[#546E7A]> $TO : $LABEL
!endprocedure

!procedure SEQ_REQ_NEW($FROM, $TO, $LABEL)
    $FROM -[$C_NEW]> $TO : $LABEL
!endprocedure

!procedure SEQ_REQ_CHG($FROM, $TO, $LABEL)
    $FROM -[$C_CHG]> $TO : $LABEL
!endprocedure

!procedure SEQ_REQ_DEL($FROM, $TO, $LABEL)
    $FROM -[$C_DEL]-> $TO : $LABEL
!endprocedure

!procedure SEQ_REQ_CFG($FROM, $TO, $LABEL)
    $FROM -[$C_CFG]> $TO : $LABEL
!endprocedure

!procedure SEQ_ASYNC($FROM, $TO, $LABEL)
    $FROM -[#546E7A]>> $TO : $LABEL
!endprocedure

!procedure SEQ_ASYNC_NEW($FROM, $TO, $LABEL)
    $FROM -[$C_NEW]>> $TO : $LABEL
!endprocedure

!procedure SEQ_ASYNC_CHG($FROM, $TO, $LABEL)
    $FROM -[$C_CHG]>> $TO : $LABEL
!endprocedure

!procedure SEQ_ASYNC_CFG($FROM, $TO, $LABEL)
    $FROM -[$C_CFG]>> $TO : $LABEL
!endprocedure

!procedure SEQ_ASYNC_DEL($FROM, $TO, $LABEL)
    $FROM -[$C_DEL]>> $TO : $LABEL
!endprocedure

!procedure SEQ_RESP($FROM, $TO, $LABEL)
    $FROM --[#546E7A]> $TO : $LABEL
!endprocedure

!procedure SEQ_RESP_OK($FROM, $TO, $LABEL)
    $FROM --[$C_NEW]> $TO : $LABEL
!endprocedure

!procedure SEQ_RESP_WARN($FROM, $TO, $LABEL)
    $FROM --[$C_WARN]> $TO : $LABEL
!endprocedure

!procedure SEQ_RESP_ERR($FROM, $TO, $LABEL)
    $FROM --[$C_CRIT]> $TO : $LABEL
!endprocedure

