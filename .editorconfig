root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.puml]
indent_size = 4

[*.pu]
indent_size = 4

[*.plantuml]
indent_size = 4

[*.iuml]
indent_size = 4

[*.wsd]
indent_size = 4
