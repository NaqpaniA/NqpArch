' ---------------------------------------------------------
' Semantic palette
' ---------------------------------------------------------
!$C_NEW      = "#00C853"
!$C_CHG      = "#2962FF"
!$C_DEL      = "#D50000"
!$C_CFG      = "#7E57C2"

!$C_INFO     = "#607D8B"
!$C_WARN     = "#FF8F00"
!$C_CRIT     = "#C62828"
!$C_NEUTRAL  = "#64748B"

!$BG_INFO    = "#EEF4FF"
!$BG_GROUP   = "#F5F7FA"
!$BG_WARN    = "#FFF8E1"
!$BG_CRIT    = "#FFEBEE"
!$BG_CFG     = "#EDEFF7"
!$BG_NEUTRAL = "#F8FAFC"

' Fragment colors must be stored without leading # because
' sequence fragment syntax already injects the # token itself.
!$FR_INFO_HEAD = "D8E2F1"
!$FR_INFO_BG   = "EEF4FF"
!$FR_WARN_HEAD = "E8D9B5"
!$FR_WARN_BG   = "FFF8E1"
!$FR_CRIT_HEAD = "E7C9C9"
!$FR_CRIT_BG   = "FFEBEE"
!$FR_NEUTRAL_BG = "F8FAFC"
!$SEQ_CURRENT_TITLE = ""

' ---------------------------------------------------------
' Text tags
' Compose them freely:
'   $B("Title")
'   $SM($MUTED("subtitle"))
'   $FONT("DejaVu Sans Mono", $WARN("payload"))
' ---------------------------------------------------------
!function $B($TEXT)
    !return "<b>" + $TEXT + "</b>"
!endfunction

!function $I($TEXT)
    !return "<i>" + $TEXT + "</i>"
!endfunction

!function $FONT($NAME, $TEXT)
    !return "<font:" + $NAME + ">" + $TEXT + "</font>"
!endfunction

!function $SIZE($VALUE, $TEXT)
    !return "<size:" + $VALUE + ">" + $TEXT + "</size>"
!endfunction

!function $COLOR($VALUE, $TEXT)
    !return "<color:" + $VALUE + ">" + $TEXT + "</color>"
!endfunction

!function $XS($TEXT)
    !return $SIZE("11", $TEXT)
!endfunction

!function $SM($TEXT)
    !return $SIZE("12", $TEXT)
!endfunction

!function $LG($TEXT)
    !return $SIZE("14", $TEXT)
!endfunction

!function $XL($TEXT)
    !return $SIZE("16", $TEXT)
!endfunction

!function $MUTED($TEXT)
    !return $COLOR($C_INFO, $TEXT)
!endfunction

!function $INFO($TEXT)
    !return $COLOR($C_INFO, $TEXT)
!endfunction

!function $WARN($TEXT)
    !return $COLOR($C_WARN, $TEXT)
!endfunction

!function $CRIT($TEXT)
    !return $COLOR($C_CRIT, $TEXT)
!endfunction

!function $NEW($TEXT)
    !return $COLOR($C_NEW, $TEXT)
!endfunction

!function $CHG($TEXT)
    !return $COLOR($C_CHG, $TEXT)
!endfunction

!function $DEL($TEXT)
    !return $COLOR($C_DEL, $TEXT)
!endfunction

!function $CFG($TEXT)
    !return $COLOR($C_CFG, $TEXT)
!endfunction

!function $MONO($TEXT)
    !return $FONT("DejaVu Sans Mono", $TEXT)
!endfunction

