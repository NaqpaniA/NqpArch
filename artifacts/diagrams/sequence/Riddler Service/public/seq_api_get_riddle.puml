@startuml
!pragma teoz true
!include ../../templates/styles/_style_seq.puml

autonumber

title
    $B("Загадывание любой загадки: stage 3")
    $SM($MUTED("Самостоятельный архитектурный артефакт"))
    $SM($MUTED("[[../Contracts/sync-riddler-service-api.yaml OpenAPI Contract]]"))
end title

footer $SM($MUTED("1 public method = 1 sequence diagram"))

box GET/v1/riddle $BG_INFO
    actor "Actor" as actor
    participant "Riddle Service" as riddler
end box

activate actor
    actor -> riddler : <<GET>> /v1/riddle(headers, query): RiddleResponse
    activate riddler
        riddler -> riddler: base validate request(requirement parameters, types)
        note left
            Первичная surface-валидация
            контракта. Отсекает
            некорректные запросы до
            вызова тяжелой бизнес-логики.
        end note
        break $BG_CRIT ValidateResponse==invalid
            riddler --> actor: <<HTTP: 400>> RiddlerResponse: (code: 100, message: "Invalid request")
        end break
        riddler -> riddler: <<sub-flow>> private.validateRequest\n(method:"GET/v1/riddle", request: {}, headers: {}): ValidateResponse
        ref over riddler
            $B("[[private_validateRequest.puml private.validateRequest]]")
            $B("method, headers, token, etc.")

            Унифицированный процесс валидации РМД.
            Включает базовые проверки токена и
            специфичные инварианты метода,
            опирающиеся на ролевую матрицу
            доступов (Active Directory, Keycloak
            или иную систему IAM).
        end ref

        break $BG_CRIT ValidateResponse != valid
            riddler --> actor: <<HTTP: 401 / 403 / 500>> Error Response
        end break

        riddler -> riddler: <<sub-flow>> private.getRiddle\n(category, difficulty, context): GetRiddleResponse
        ref over riddler
            $B("[[private_getRiddle.puml private.getRiddle]]")
            $B("category, difficulty, context")

            Эвристический подбор релевантной загадки
            из каталога с учетом контекста, желаемой
            сложности и пользовательских предпочтений.
        end ref
        break $BG_CRIT GetRiddleResponse==notFound
            riddler --> actor: <<HTTP: 404>> RiddleResponse: (code: 404, message: "Not Found")
        end break

        riddler -> riddler: <<sub-flow>> private.createSession\n(riddleId, x-user-id): SessionResponse
        ref over riddler
            $B("[[private_createSession.puml private.createSession]]")
            $B("riddleId, x-user-id")

            Инициализация защищенной сессии.
            Формирует персистентную запись в Session Store
            для последующей верификации ответа пользователя.
        end ref
        break $BG_CRIT SessionResponse==error
            riddler --> actor: <<HTTP: 500>> Internal Server Error
        end break

        riddler --> actor: <<HTTP: 200>> RiddleResponse: (code: 0, message: "OK", data: "{riddleId, category, difficulty, context}")

    deactivate riddler
deactivate actor

SEQ_LEGEND_STATUS()
@enduml
