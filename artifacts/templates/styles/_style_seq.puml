skinparam responseMessageBelowArrow true
skinparam sequenceMessageAlign left

skinparam sequence {
    ArrowThickness 2
    MessageAlign left
    ParticipantPadding 24
    BoxPadding 10
    LifeLineBorderColor #B0BEC5
    LifeLineBackgroundColor #FFFFFF
}

' ---------------------------------------------------------
' Participants
' ---------------------------------------------------------
skinparam participant {
    BorderColor #90A4AE
