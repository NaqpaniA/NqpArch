' ---------------------------------------------------------
' Legend macros
' ---------------------------------------------------------
!procedure SEQ_LEGEND_STATUS()
    legend top left
        |Mark     | Meaning  |<#000000>|Mark      | Meaning  |
        |<$C_NEW> | new      |<#000000>|<#EEF4FF> | info     |
        |<$C_CHG> | changed  |<#000000>|<#FFF8E1> | warning  |
        |<$C_DEL> | removed  |<#000000>|<#FFEBEE> | critical |
        |<$C_CFG> | config   |<#000000>|
    endlegend
!endprocedure

!procedure SEQ_LEGEND_PARTICIPANTS()
    legend bottom left
        |= Participant |= Meaning |
        |<#E8F5E9> | new service     |
        |<#EEF4FF> | changed service |
        |<#FFEBEE> | removed service |
        |<#FFF8E1> | legacy service  |
        |<#EDEFF7> | configuration   |
    endlegend
!endprocedure

!procedure SEQ_LEGEND_FULL_TOP_RIGHT()
    legend top right
        |= Mark |= Meaning |
        |<$C_NEW> | new / introduced |
        |<$C_CHG> | changed |
        |<$C_DEL> | removed |
        |<$C_CFG> | configuration |
        |<#E8F5E9> | new participant |
        |<#EEF4FF> | changed participant |
        |<#FFEBEE> | removed participant |
        |<#FFF8E1> | legacy participant |
        |<#EDEFF7> | configuration source |
    endlegend
!endprocedure

!procedure $LEGEND_STATUS_SEQ()
    SEQ_LEGEND_STATUS()
!endprocedure

' ---------------------------------------------------------
' Title / headers / footers
' ---------------------------------------------------------
!procedure SEQ_TITLE($TEXT)
    !$SEQ_CURRENT_TITLE = $TEXT
    title $TEXT
!endprocedure

!procedure SEQ_SUBTITLE($TEXT)
    title $SEQ_CURRENT_TITLE\n$TEXT
!endprocedure

!procedure SEQ_HEADER($TEXT)
    header $TEXT
!endprocedure

!procedure SEQ_FOOTER($TEXT)
    footer $TEXT
!endprocedure

!procedure SEQ_TITLE_NOT_RECOMMENDED($TEXT)
    title $B($TEXT)\n$SM($CRIT($B("NOT RECOMMENDED BY ARCHITECTURE")))
!endprocedure

!procedure SEQ_HEADER_WARN($TEXT)
    header $B($WARN($TEXT))
!endprocedure

!procedure SEQ_FOOTER_NOTE($TEXT)
    footer $SM($MUTED($TEXT))
!endprocedure

' ---------------------------------------------------------
' Sections / timing markers
' ---------------------------------------------------------
!procedure SEQ_SECTION($TEXT)
    == <b>$TEXT</b> ==
!endprocedure

!procedure SEQ_DELAY($TEXT)
    ... <b>$TEXT</b> ...
!endprocedure

