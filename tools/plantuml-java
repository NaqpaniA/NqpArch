#!/usr/bin/env bash

set -euo pipefail

pick_java() {
  if command -v java >/dev/null 2>&1; then
    command -v java
    return 0
  fi

  if [[ -x "${HOME}/.jdks/openjdk-25.0.2/bin/java" ]]; then
    printf '%s\n' "${HOME}/.jdks/openjdk-25.0.2/bin/java"
    return 0
  fi

  local candidate

  while IFS= read -r candidate; do
    [[ -x "${candidate}" ]] || continue
    printf '%s\n' "${candidate}"
    return 0
  done < <(find "${HOME}/.jdks" /usr/lib/jvm -type f -path '*/bin/java' 2>/dev/null | sort -V)

  return 1
}

JAVA_BIN="$(pick_java || true)"

if [[ -z "${JAVA_BIN}" ]]; then
  echo "PlantUML: java runtime not found. Install JDK or expose java in PATH." >&2
  exit 127
fi

exec "${JAVA_BIN}" "$@"
